{
  "manifest_version": 3,
  "name": "CALDERA",
  "version": "0.1.0",
  "description": "Send Nexus Mods downloads to CALDERA",
  "permissions": ["scripting", "activeTab"],
  "host_permissions": [
    "https://www.nexusmods.com/*",
    "http://localhost:7337/*",
    "http://127.0.0.1:7337/*",
    "http://127.69.67.21:7337/*"
  ],
  "content_scripts": [
    {
      "matches": ["https://www.nexusmods.com/*/mods/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "icons": {
    "16": "icon16.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "caldera@madebybark.com",
      "strict_min_version": "109.0"
    }
  }
}
