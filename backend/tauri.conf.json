{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CALDERA",
  "version": "0.1.1",
  "identifier": "dev.caldera.app",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "CALDERA",
        "width": 1280,
        "height": 800
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/.config/caldera/**",
          "$APPCONFIG/caldera/**",
          "$APPDATA/caldera/**",
          "$APPLOCALDATA/caldera/**",
          "$HOME/.steam/**",
          "$HOME/.local/share/Steam/**",
          "$LOCALDATA/Steam/**",
          "$APPDATA/Steam/**"
        ]
      }
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["nxm"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm", "appimage", "msi", "nsis"],
    "category": "Utility",
    "shortDescription": "Cross-platform mod manager",
    "longDescription": "CALDERA — Linux-first mod manager rivaling Vortex.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/256x256.png",
      "icons/512x512.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
